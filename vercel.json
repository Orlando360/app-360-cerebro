{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "functions": {
    "src/app/api/inngest/route.ts": { "maxDuration": 300 },
    "src/app/api/procesar-diagnostico/route.ts": { "maxDuration": 60 },
    "src/app/api/**/*.ts": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/health", "schedule": "*/10 * * * *" },
    { "path": "/api/inngest", "schedule": "*/5 * * * *" }
  ]
}
